{
  "name": "kineforge",
  "version": "1.0.0",
  "description": "A browser-based tool for animating SVG files and exporting them as animated SVGs or React components powered by Motion.",
  "license": "CC-BY-NC-4.0",
  "type": "module",
  "packageManager": "yarn@4.5.2",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "tsc --noEmit && eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "resolutions": {
    "vite": "^6.2.0",
    "lodash": "4.17.21",
    "workbox-build/source-map": "0.7.4",
    "workbox-build/@rollup/plugin-replace": "^6.0.0",
    "workbox-build/glob": "^11.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.14.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lodash": "^4.17.21",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  }
}
